es_actual_id,\n","dias_restantes, # el consumo_mes ya fue ajustado, se divide entre los días que quedan\n","forecast_mensual[\"dias_mes\"]\n",")\n","forecast_mensual[\"consumo_diario\"] = (\n","forecast_mensual[\"consumo_mes\"] / forecast_mensual[\"dias_denominador\"]\n",")\n","\n","forecast_mensual.head()\n"]},{"cell_type":"code","execution_count":25,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":136552,"status":"ok","timestamp":1782141977511,"user":{"displayName":"Francisco Enrique González Morales","userId":"17046962551082790183"},"user_tz":240},"id":"n6iTc6rPAca1","outputId":"14c317d1-63cf-4140-db0b-e4058100afba"},"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_1177/975629130.py:161: FutureWarning: The behavior of DataFrame concatenation with empty or all-NA entries is deprecated. In a future version, this will no longer exclude empty or all-NA columns when determining the result dtypes. To retain the old behavior, exclude the relevant entries before the concat operation.\n","  tiendas_stock[t] = pd.concat(\n","/tmp/ipykernel_1177/975629130.py:161: FutureWarning: The behavior of DataFrame concatenation with empty or all-NA entries is deprecated. In a future version, this will no longer exclude empty or all-NA columns when determining the result dtypes. To retain the old behavior, exclude the relevant entries before the concat operation.\n","  tiendas_stock[t] = pd.concat(\n","/tmp/ipykernel_1177/975629130.py:161: FutureWarning: The behavior of DataFrame concatenation with empty or all-NA entries is deprecated. In a future version, this will no longer exclude empty or all-NA columns when determining the result dtypes. To retain the old behavior, exclude the relevant entries before the concat operation.\n","  tiendas_stock[t] = pd.concat(\n","/tmp/ipykernel_1177/975629130.py:161: FutureWarning: The behavior of DataFrame concatenation with empty or all-NA entries is deprecated. In a future version, t