x(drop=True)\n","/tmp/ipykernel_1177/975629130.py:142: FutureWarning: The behavior of DataFrame concatenation with empty or all-NA entries is deprecated. In a future version, this will no longer exclude empty or all-NA columns when determining the result dtypes. To retain the old behavior, exclude the relevant entries before the concat operation.\n","  cd = pd.concat([cd, nuevos_prep], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n"]},{"output_type":"stream","name":"stdout","text":["✅ Motor diario terminado\n","Obsolescencia lotes: (359, 9)\n","Balance diario:      (72584, 9)\n","\n","Vencimiento por origen:\n","                origen store_code  qty_vencida\n","transito_prep_estimado         CD 47327.800802\n","            OL_inicial         CD 43277.315852\n","        tienda_inicial    594_IFB 11406.854360\n","        tienda_inicial    636_IFB  9904.791140\n","            OL_inicial      59400  6846.836076\n","            OL_inicial      63600  4413.418961\n","transito_prep_estimado      59400   162.815263\n","transito_prep_estimado      63600   156.874837\n"]}],"source":["### CELDA 10 — Motor integrado diario (Inventario + Obsolescencia) ### (Cambiar en def dias corte la cantidad de dias previo a la fecha de vencimiento donde se termina la venta del producto)\n","\n","process_date = pd.Timestamp.today().normalize()\n","\n","ultimo_mes_fcst = forecast_mensual[\"mes_id\"].max()\n","fin_simulacion  = pd.Period(ultimo_mes_fcst, freq=\"M\").to_timestamp(how=\"end\").normalize()\n","calendario      = pd.date_range(process_date, fin_simulacion, freq=\"D\")\n","\n","def dias_corte_por_hfb(hfb):\n","    try:\n","        hfb_int = int(hfb)\n","    except (TypeError, ValueError):\n","        hfb_int = None\n","    if hfb_int == 60:\n","        return 0\n","    if hfb_int == 61:\n","        return 7\n","    return 7\n","\n","items_con_forecast = forecast_mensual[[\"item_no\"]].drop_duplicates()\n","\n","items_con_stock = pd.concat([\n","    stock_tienda_por_vencimiento[[\"item_no\"]],\n","    stock_cd_por_vencimiento[[\"item_no\"]],\n","    arribos_lote[[\"item_no\"]],\n","    arribos_sin_lote[[\"item_no\"]],\n","    items_con_forecast\n","]).drop_duplicates()[\"item_no\"]\n","\n","fc_lookup = (\n","    forecast_mensual\n","    .set_index([\"item_no\", \"store_code\", \"mes_id\"])[\"consumo_mes\"]\n","    .to_dict()\n",")\n","fc_diario_lookup = (\n","    forecast_mensual\n","    .set_index([\"item_no\", \"store_code\", \"mes_id\"])[\"consumo_diario\"]\n","    .to_dict()\n",")\n","\n","SHELF_FAR  = pd.Timestamp(\"2099-12-31\")\n","obs_rows   = []\n","daily_rows = []\n","\n","_obs_schema = [\"item_no\", \"store_code\", \"expiration_date\", \"fecha_fin_consumo\",\n","               \"obs_date\", \"qty_vencida\", \"origen\",\n","               \"Home_Furnishing_Business_No\", \"process_date\"]\n","\n","for item in items_con_stock:\n","\n","    hfb_series = items_master.loc[items_master[\"item_no\"] == item, \"Home_Furnishing_Business_No\"]\n","    hfb        = int(hfb_series.iloc[0]) if len(hfb_series) > 0 and pd.notna(hfb_series.iloc[0]) else None\n","    dias_corte = dias_corte_por_hfb(hfb)\n","\n","    # ── Stock OL inicial ──\n","    cd = stock_cd_por_vencimiento[stock_cd_por_vencimiento[\"item_no\"] == item][\n","        [\"expiration_date\", \"qty\"]\n","    ].copy()\n","    cd[\"expiration_date\"] = pd.to_datetime(cd[\"expiration_date\"]).dt.normalize()\n","    cd[\"qty\"]             = cd[\"qty\"].astype(float)\n","    cd[\"origen\"]          = \"OL_inicial\"                          # ← TAG\n","    if not cd.empty:\n","        cd[\"fecha_fin_consumo\"] = cd[\"expiration_date\"] - pd.Timedelta(days=dias_corte)\n","        cd = cd[cd[\"fecha_fin_consumo\"] >= process_date].reset_index(drop=True)\n","    else:\n","        cd = pd.DataFrame(columns=[\"expiration_date\", \"qty\", \"fecha_fin_consumo\", \"origen\"])\n","    cd = cd.sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","\n","    # ── Stock tienda inicial ──\n","    tiendas = stock_tienda_por_vencimiento[\n","        stock_tienda_por_vencimiento[\"item_no\"] == item\n","    ][\"store_code\"].unique()\n","\n","    tiendas_stock = {}\n","    for t in tiendas:\n","        st = stock_tienda_por_vencimiento[\n","            (stock_tienda_por_vencimiento[\"item_no\"] == item) &\n","            (stock_tienda_por_vencimiento[\"store_code\"] == t)\n","        ][[\"expiration_date\", \"qty\"]].copy()\n","        st[\"expiration_date\"]   = pd.to_datetime(st[\"expiration_date\"]).dt.normalize()\n","        st[\"qty\"]               = st[\"qty\"].astype(float)\n","        st[\"origen\"]            = \"tienda_inicial\"                # ← TAG\n","        st[\"fecha_fin_consumo\"] = st[\"expiration_date\"] - pd.Timedelta(days=dias_corte)\n","        st = st[st[\"fecha_fin_consumo\"] >= process_date].reset_index(drop=True)\n","        st = st.sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","        tiendas_stock[t] = st\n","\n","    # ── Tiendas solo en forecast (sin stock inicial) ──\n","    tiendas_en_fcst = forecast_mensual[forecast_mensual[\"item_no\"] == item][\"store_code\"].unique()\n","    for t in tiendas_en_fcst:\n","        if t not in tiendas_stock:\n","            tiendas_stock[t] = pd.DataFrame(\n","                columns=[\"expiration_date\", \"qty\", \"fecha_fin_consumo\", \"origen\"]\n","            )\n","\n","    meses_reabastecidos = {t: set() for t in tiendas_stock}\n","\n","    for dia in calendario:\n","        mes_id     = dia.to_period(\"M\").strftime(\"%Y-%m\")\n","        primer_dia = (dia == dia.to_period(\"M\").to_timestamp())\n","\n","        inv_inicio_dia = (\n","            float(cd[\"qty\"].sum()) +\n","            sum(float(df[\"qty\"].sum()) for df in tiendas_stock.values())\n","        )\n","\n","        # ── 0a) Arribos con lote (En tránsito) → OL ──\n","        lotes_hoy = arribos_lote[\n","            (arribos_lote[\"item_no\"] == item) &\n","            (arribos_lote[\"available_date\"] == dia)\n","        ]\n","        arribo_lote_qty = float(lotes_hoy[\"qty\"].sum()) if not lotes_hoy.empty else 0.0\n","        if not lotes_hoy.empty:\n","            nuevos = lotes_hoy[[\"expiration_date\", \"qty\"]].copy()\n","            nuevos[\"expiration_date\"]   = pd.to_datetime(nuevos[\"expiration_date\"]).dt.normalize()\n","            nuevos[\"qty\"]               = nuevos[\"qty\"].astype(float)\n","            # distinguir BBD real vs estimado según flag origen_estimado\n","            if \"origen_estimado\" in lotes_hoy.columns:\n","                nuevos[\"origen\"] = lotes_hoy[\"origen_estimado\"].apply(\n","                    lambda x: \"transito_prep_estimado\" if x is True else \"transito_lote\"\n","                ).values\n","            else:\n","                nuevos[\"origen\"] = \"transito_lote\"                # ← TAG\n","            nuevos[\"fecha_fin_consumo\"] = nuevos[\"expiration_date\"] - pd.Timedelta(days=dias_corte)\n","            nuevos = nuevos[nuevos[\"fecha_fin_consumo\"] >= dia]\n","            if not nuevos.empty:\n","                cd = pd.concat([cd, nuevos], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","\n","        # ── 0b) Arribos sin lote (En preparación sin historial) → OL ──\n","        prep_hoy = arribos_sin_lote[\n","            (arribos_sin_lote[\"item_no\"] == item) &\n","            (arribos_sin_lote[\"available_date\"] == dia)\n","        ]\n","        arribo_prep_qty = float(prep_hoy[\"qty\"].sum()) if not prep_hoy.empty else 0.0\n","        if arribo_prep_qty > 0:\n","            nuevos_prep = pd.DataFrame([{\n","                \"expiration_date\":   SHELF_FAR,\n","                \"qty\":               arribo_prep_qty,\n","                \"fecha_fin_consumo\": SHELF_FAR,\n","                \"origen\":            \"transito_sin_lote\"          # ← TAG\n","            }])\n","            cd = pd.concat([cd, nuevos_prep], ignore_index=True).