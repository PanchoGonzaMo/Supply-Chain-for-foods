-4f7c-f53d-552cd1c286e5"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading: 100%|\u001b[32m██████████\u001b[0m|\n"]}]},{"cell_type":"code","source":["## Lectura Stock de tienda ##\n","\n","stock_ikea = read_gbq(\n","    \"\"\"\n","    WITH last_load AS (\n","        SELECT MAX(load_date) AS max_load_date\n","        FROM `tc-sc-bi-bigdata-ikea-corp-qa.Availability_FOOD_CL.rbitems_food_cl`\n","    )\n","    SELECT\n","        ITEM_NO AS item_no,\n","        LOCATION_CODE AS store_code,\n","        SUM(SAFE_CAST(STOCK AS FLOAT64)) AS stock_total\n","    FROM `tc-sc-bi-bigdata-ikea-corp-qa.Availability_FOOD_CL.rbitems_food_cl`\n","    WHERE load_date = (SELECT max_load_date FROM last_load)\n","    GROUP BY\n","        ITEM_NO,\n","        LOCATION_CODE\n","    HAVING\n","        SUM(SAFE_CAST(STOCK AS FLOAT64)) <> 0\n","    \"\"\",\n","    project_id=\"tc-sc-bi-bigdata-ikea-corp-qa\"\n",")"],"metadata":{"id":"Y_0Uq8op4bVp","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1782141756040,"user_tz":240,"elapsed":510,"user":{"displayName":"Francisco Enrique González Morales","userId":"17046962551082790183"}},"outputId":"b3c294e5-4872-4e85-fa5f-498bef2ff3e3"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading: 100%|\u001b[32m██████████\u001b[0m|\n"]}]},{"cell_type":"code","source":["### Carga de envios ###\n","from pandas_gbq import read_gbq\n","\n","shipments = read_gbq(\n","    \"\"\"\n","    SELECT\n","        Codigo_MVBC AS item_no,\n","        Tienda AS store_code,\n","        SAFE_CAST(Fecha_confirmacion AS DATE) AS shipment_date,\n","        Fecha_Vencimiento AS expiration_date,\n","        SAFE_CAST(Cantidad_Enviada AS FLOAT64) AS qty_sent\n","    FROM `tc-sc-bi-bigdata-ikea-corp-qa.Availability_FOOD_CL.Consolidado_envios_OL_Normalizado`\n","    WHERE Cantidad_Enviada IS NOT NULL\n","    \"\"\",\n","    project_id=\"tc-sc-bi-bigdata-ikea-corp-qa\"\n",")\n"],"metadata":{"id":"0VMloW2V47w8","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1782141756711,"user_tz":240,"elapsed":667,"user":{"displayName":"Francisco Enrique González Morales","userId":"17046962551082790183"}},"outputId":"6508cfa0-66fb-40f7-943f-22eccfcc7fc3"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading: 100%|\u001b[32m██████████\u001b[0m|\n"]}]},{"cell_type":"code","source":["### FEFO Retroactivo ###\n","def fefo_retroactivo(stock_tienda, df_envios):\n","    \"\"\"\n","    Reconstruye el stock por fecha de vencimiento\n","    usando FEFO retroactivo (envíos más nuevos primero)\n","    \"\"\"\n","    stock_restante = stock_tienda\n","    resultado = []\n","\n","    df_envios = df_envios.sort_values(\n","        \"shipment_date\", ascending=False\n","    )\n","\n","    for _, row in df_envios.iterrows():\n","        if stock_restante <= 0:\n","            break\n","\n","        tomar = min(stock_restante, row[\"qty_sent\"])\n","\n","        resultado.append({\n","            \"expiration_date\": row[\"expiration_date\"],\n","            \"qty\": tomar\n","        })\n","\n","        stock_restante -= tomar\n","\n","    return pd.DataFrame(resultado)"],"metadata":{"id":"eyqpu3O8Ditg","executionInfo":{"status":"ok","timestamp":1782141756727,"user_tz":240,"elapsed":6,"user":{"displayName":"Francisco Enrique González Morales","userId":"17046962551082790183"}}},"execution_count":8,"outputs":[]},{"cell_type":"code","source":["### Aplicacion tienda - producto ###\n","\n","# --- Normalización de claves (arregla el float-string \"10002073.0\" vs \"10002073\") ---\n","def norm_item(s):\n","    s = str(s).strip()\n","    try:\n","        f = float(s)\n","        if f.is_integer():\n","            return str(int(f))   # \"10002073.0\" / \"10002073.00\" -> \"10002073\"\n","    except (ValueError, TypeError):\n","        pass\n","    return s                     # deja intactos los no numéricos\n","\n","stock_ikea[\"item_no\"]    = stock_ikea[\"item_no\"].map(norm_item)\n","shipments[\"item_no\"]     = shipments[\"item_no\"].map(norm_item)\n","stock_ikea[\"store_code\"] = stock_ikea[\"store_code\"].astype(str).str.strip()\n","shipments[\"store_code\"]  = shipments[\"store_code\"].astype(str).str.strip()\n","\n","# --- FEFO retroactivo por item / tienda ---\n","resultados = []\n","\n","for _, stock_row in stock_ikea.iterrows():\n","    item   = stock_row[\"item_no\"]\n","    tienda = stock_row[\"store_code\"]\n","    stock  = stock_row[\"stock_total\"]\n","\n","    envios_filtrados = shipments[\n","        (shipments[\"item_no\"] == item) &\n","        (shipments[\"store_code\"] == tienda)\n","    ]\n","\n","    if envios_filtrados.empty or stock <= 0:\n","        continue\n","\n","    reconstruido = fefo_retroactivo(stock, envios_filtrados)\n","\n","    if not reconstruido.empty:\n","        reconstruido[\"item_no\"]    = item\n","        reconstruido[\"store_code\"] = tienda\n","        resultados.append(reconstruido)\n","\n","# --- Guard: mensaje claro si no hubo coincidencias ---\n","if not resultados:\n","    raise ValueError(\n","        \"Sin coincidencias item_no + store_code. \"\n","        \"Revisa formato de claves o que 'shipments' no esté vacío.\"\n","    )\n","\n","stock_tienda_por_vencimiento = pd.concat(resultados, ignore_index=True)\n","\n","print(\"✅ FEFO retroactivo:\", stock_tienda_por_vencimiento.shape,\n","      \"| items:\", stock_tienda_por_vencimiento['item_no'].nunique(),\n","      \"| tiendas:\", stock_tienda_por_vencimiento['store_code'].nunique())"],"metadata":{"id":"kKaXM3CVDxI2","executionInfo":{"status":"ok","timestamp":1782141757412,"user_tz":240,"elapsed":635,"user":{"displayName":"Francisco Enrique González Morales","userId":"17046962551082790183"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"977e573a-ec91-4fe6-c45b-721740cf06c0"},"execution_count":9,"outputs":[{"output_type":"stream","