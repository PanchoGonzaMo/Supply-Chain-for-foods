,\n","    a.Status_confirmacion,\n","    a.Lote,\n","    a.Tipo_almacen_destino,\n","    a.Ubicacion_de_destino,\n","    a.Ctd_real_dest,\n","    a.Fecha_confirmacion,\n","    a.Hora_de_confirmacion,\n","    a.Usuario,\n","    a.Unidad_de_medida_alternativa,\n","    a.Clase_de_movimiento,\n","    a.Cl_movimiento_WM,\n","    a.Un_alm_procedencia,\n","    a.Almacen,\n","    a.Transaccion,\n","    a.MovCant,\n","    a.TipoMOV,\n","\n","    SAFE.PARSE_DATE('%d%m%Y', SUBSTR(a.Lote, 3, 8)) AS Fecha_Vencimiento,\n","\n","    CASE\n","        WHEN a.TipoMOV = 'OUT IOK' THEN '594_IFB'\n","        WHEN a.TipoMOV = 'OUT IPO' THEN '636_IFB'\n","        ELSE NULL\n","    END AS Tienda,\n","\n","    e.Codigo_MVBC,\n","    e.Descripcion_MVBC,\n","    e.Q_x_EMB,\n","    e.KG_x_UN,\n","    e.UoM_Base,\n","\n","    CASE\n","        WHEN e.UoM_Base = 'PC' THEN\n","            SAFE_CAST(a.MovCant AS NUMERIC) * e.Q_x_EMB\n","        WHEN e.UoM_Base = 'KG' THEN\n","            SAFE_CAST(a.MovCant AS NUMERIC) * e.Q_x_EMB * e.KG_x_UN\n","        ELSE NULL\n","    END AS Cantidad_Enviada\n","\n","FROM\n","`tc-sc-bi-bigdata-ikea-corp-qa.Availability_FOOD_CL.Consolidado_envios_OL` a\n","LEFT JOIN\n","Equivalencias_dedup e\n","ON REGEXP_REPLACE(TRIM(CAST(a.Material AS STRING)), r'\\\\.0+$', '') = e.Material_key;\n","\"\"\"\n","\n","read_gbq(query_normalizado, project_id=PROJECT_ID)\n","print(\"✅ Tabla Consolidado_envios_OL_Normalizado actualizada\")"],"metadata":{"id":"RSrnO9z_63CI","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1782141754823,"user_tz":240,"elapsed":19595,"user":{"displayName":"Francisco Enrique González Morales","userId":"17046962551082790183"}},"outputId":"101ba30d-188b-4caa-dcca-205147b55812"},"execution_count":1,"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading: |\u001b[32m          \u001b[0m|\n","✅ Tabla Consolidado_envios_OL_Normalizado actualizada\n"]}]},{"cell_type":"code","execution_count":2,"metadata":{