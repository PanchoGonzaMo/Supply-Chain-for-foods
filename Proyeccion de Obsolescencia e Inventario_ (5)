columns when determining the result dtypes. To retain the old behavior, exclude the relevant entries before the concat operation.\n","  cd = pd.concat([cd, nuevos], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","/tmp/ipykernel_381/4020867442.py:115: FutureWarning: The behavior of DataFrame concatenation with empty or all-NA entries is deprecated. In a future version, this will no longer exclude empty or all-NA columns when determining the result dtypes. To retain the old behavior, exclude the relevant entries before the concat operation.\n","  cd = pd.concat([cd, nuevos], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","/tmp/ipykernel_381/4020867442.py:115: FutureWarning: The behavior of DataFrame concatenation with empty or all-NA entries is deprecated. In a future version, this will no longer exclude empty or all-NA columns when determining the result dtypes. To retain the old behavior, exclude the relevant entries before the concat operation.\n","  cd = pd.concat([cd, nuevos], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","/tmp/ipykernel_381/4020867442.py:115: FutureWarning: The behavior of DataFrame concatenation with empty or all-NA entries is deprecated. In a future version, this will no longer exclude empty or all-NA columns when determining the result dtypes. To retain the old behavior, exclude the relevant entries before the concat operation.\n","  cd = pd.concat([cd, nuevos], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","/tmp/ipykernel_381/4020867442.py:115: FutureWarning: The behavior of DataFrame concatenation with empty or all-NA entries is deprecated. In a future version, this will no longer exclude empty or all-NA columns when determining the result dtypes. To retain the old behavior, exclude the relevant entries before the concat operation.\n","  cd = pd.concat([cd, nuevos], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","/tmp/ipykernel_381/4020867442.py:115: FutureWarning: The behavior of DataFrame concatenation with empty or all-NA entries is deprecated. In a future version, this will no longer exclude empty or all-NA columns when determining the result dtypes. To retain the old behavior, exclude the relevant entries before the concat operation.\n","  cd = pd.concat([cd, nuevos], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","/tmp/ipykernel_381/4020867442.py:130: FutureWarning: The behavior of DataFrame concatenation with empty or all-NA entries is deprecated. In a future version, this will no longer exclude empty or all-NA columns when determining the result dtypes. To retain the old behavior, exclude the relevant entries before the concat operation.\n","  cd = pd.concat([cd, nuevos_prep], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n"]},{"output_type":"stream","name":"stdout","text":["✅ Motor diario terminado (pool de tiendas consolidado)\n","Obsolescencia lotes: (105, 9)\n","Balance diario:      (81366, 9)\n","\n","Vencimiento por origen:\n","                origen store_code  qty_vencida\n","transito_prep_estimado         CD 80842.786645\n","            OL_inicial         CD 32896.188028\n","            OL_inicial    TIENDAS  7863.591202\n","        tienda_inicial    TIENDAS  2437.452245\n","transito_prep_estimado    TIENDAS  2318.514144\n"]}],"source":["### CELDA 10 — Motor integrado diario (Inventario + Obsolescencia) — POOL DE TIENDAS ###\n","# NOTA DE NEGOCIO: 594_IFB y 636_IFB se simulan como UN SOLO pool de inventario,\n","# porque operación realiza balanceos internos entre tiendas cuando hay desbalance\n","# de stock. Por eso el motor ya NO calcula consumo/quiebre/vencimiento por tienda\n","# individual — el store_code de salida para eventos en tienda pasa a ser\n","# \"TIENDAS\" (consolidado). El CD/OL (`cd`) se mantiene separado porque ahí sí\n","# importa el origen físico para decidir el reabasto.\n","# (Cambiar en def dias_corte_por_hfb la cantidad de días previos al vencimiento\n","# donde se termina la venta del producto)\n","\n","process_date = pd.Timestamp.today().normalize()\n","\n","ultimo_mes_fcst = forecast_mensual[\"mes_id\"].max()\n","fin_simulacion  = pd.Period(ultimo_mes_fcst, freq=\"M\").to_timestamp(how=\"end\").normalize()\n","calendario      = pd.date_range(process_date, fin_simulacion, freq=\"D\")\n","\n","def dias_corte_por_hfb(hfb):\n","    try:\n","        hfb_int = int(hfb)\n","    except (TypeError, ValueError):\n","        hfb_int = None\n","    if hfb_int == 60:\n","        return 0\n","    if hfb_int == 61:\n","        return 7\n","    return 7\n","\n","items_con_forecast = forecast_mensual[[\"item_no\"]].drop_duplicates()\n","\n","items_con_stock = pd.concat([\n","    stock_tienda_por_vencimiento[[\"item_no\"]],\n","    stock_cd_por_vencimiento[[\"item_no\"]],\n","    arribos_lote[[\"item_no\"]],\n","    arribos_sin_lote[[\"item_no\"]],\n","    items_con_forecast\n","]).drop_duplicates()[\"item_no\"]\n","\n","# ── Demanda consolidada por item/mes (pool de tiendas: suma 594_IFB + 636_IFB) ──\n","forecast_pool = (\n","    forecast_mensual\n","    .groupby([\"item_no\", \"mes_id\"], as_index=False)\n","    .agg(consumo_mes=(\"consumo_mes\", \"sum\"), consumo_diario=(\"consumo_diario\", \"sum\"))\n",")\n","fc_lookup        = forecast_pool.set_index([\"item_no\", \"mes_id\"])[\"consumo_mes\"].to_dict()\n","fc_diario_lookup = forecast_pool.set_index([\"item_no\", \"mes_id\"])[\"consumo_diario\"].to_dict()\n","\n","SHELF_FAR  = pd.Timestamp(\"2099-12-31\")\n","obs_rows   = []\n","daily_rows = []\n","\n","_obs_schema = [\"item_no\", \"store_code\", \"expiration_date\", \"fecha_fin_consumo\",\n","               \"obs_date\", \"qty_vencida\", \"origen\",\n","               \"Home_Furnishing_Business_No\", \"process_date\"]\n","\n","TIENDA_POOL_LABEL = \"TIENDAS\"   # store_code de salida para eventos consolidados de tienda\n","\n","for item in items_con_stock:\n","\n","    hfb_series = items_master.loc[items_master[\"item_no\"] == item, \"Home_Furnishing_Business_No\"]\n","    hfb        = int(hfb_series.iloc[0]) if len(hfb_series) > 0 and pd.notna(hfb_series.iloc[0]) else None\n","    dias_corte = dias_corte_por_hfb(hfb)\n","\n","    # ── Stock OL inicial ──\n","    cd = stock_cd_por_vencimiento[stock_cd_por_vencimiento[\"item_no\"] == item][\n","        [\"expiration_date\", \"qty\"]\n","    ].copy()\n","    cd[\"expiration_date\"] = pd.to_datetime(cd[\"expiration_date\"]).dt.normalize()\n","    cd[\"qty\"]             = cd[\"qty\"].astype(float)\n","    cd[\"origen\"]          = \"OL_inicial\"\n","    if not cd.empty:\n","        cd[\"fecha_fin_consumo\"] = cd[\"expiration_date\"] - pd.Timedelta(days=dias_corte)\n","        cd = cd[cd[\"fecha_fin_consumo\"] >= process_date].reset_index(drop=True)\n","    else:\n","        cd = pd.DataFrame(columns=[\"expiration_date\", \"qty\", \"fecha_fin_consumo\", \"origen\"])\n","    cd = cd.sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","\n","    # ── Stock tienda inicial: POOL consolidado (todas las tiendas del item juntas) ──\n","    tienda_pool = stock_tienda_por_vencimiento[\n","        stock_tienda_por_vencimiento[\"item_no\"] == item\n","    ][[\"expiration_date\", \"qty\"]].copy()\n","    tienda_pool[\"expiration_date\"]   = pd.to_datetime(tienda_pool[\"expiration_date\"]).dt.normalize()\n","    tienda_pool[\"qty\"]               = tienda_pool[\"qty\"].astype(float)\n","    tienda_pool[\"origen\"]            = \"tienda_inicial\"\n","    tienda_pool[\"fecha_fin_consumo\"] = tienda_pool[\"expiration_date\"] - pd.Timedelta(days=dias_corte)\n","    tienda_pool = tienda_pool[tienda_pool[\"fecha_fin_consumo\"] >= process_date].reset_index(drop=True)\n","    tienda_pool = tienda_pool.sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","\n","    meses_reabastecidos = set()\n","\n","    for dia in calendario:\n","        mes_id     = dia.to_period(\"M\").strftime(\"%Y-%m\")\n","        primer_dia = (dia == dia.to_period(\"M\").to_timestamp())\n","\n","        inv_inicio_dia = float(cd[\"qty\"].sum()) + float(tienda_pool[\"qty\"].sum())\n","\n","        # ── 0a) Arribos con lote (En tránsito) → OL ──\n","        lotes_hoy = arribos_lote[\n","            (arribos_lote[\"item_no\"] == item) &\n","            (arribos_lote[\"available_date\"] == dia)\n","        ]\n","        arribo_lote_qty = float(lotes_hoy[\"qty\"].sum()) if not lotes_hoy.empty else 0.0\n","        if not lotes_hoy.empty:\n","            nuevos = lotes_hoy[[\"expiration_date\", \"qty\"]].copy()\n","            nuevos[\"expiration_date\"] = pd.to_datetime(nuevos[\"expiration_date\"]).dt.normalize()\n","            nuevos[\"qty\"]             = nuevos[\"qty\"].astype(float)\n","            if \"origen_estimado\" in lotes_hoy.columns:\n","                nuevos[\"origen\"] = lotes_hoy[\"origen_estimado\"].apply(\n","                    lambda x: \"transito_prep_estimado\" if x is True else \"transito_lote\"\n","                ).values\n","            else:\n","                nuevos[\"origen\"] = \"transito_lote\"\n","            nuevos[\"fecha_fin_consumo\"] = nuevos[\"expiration_date\"] - pd.Timedelta(days=dias_corte)\n","            nuevos = nuevos[nuevos[\"fecha_fin_consumo\"] >= dia]\n","            if not nuevos.empty:\n","                cd = pd.concat([cd, nuevos], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","\n","        # ── 0b) Arribos sin lote (En preparación sin historial) → OL ──\n","        prep_hoy = arribos_sin_lote[\n","            (arribos_sin_lote[\"item_no\"] == item) &\n","            (arribos_sin_lote[\"available_date\"] == dia)\n","        ]\n","        arribo_prep_qty = float(prep_hoy[\"qty\"].sum()) if not prep_hoy.empty else 0.0\n","        if arribo_prep_qty > 0:\n","            nuevos_prep = pd.DataFrame([{\n","                \"expiration_date\":   SHELF_FAR,\n","                \"qty\":               arribo_prep_qty,\n","                \"fecha_fin_consumo\": SHELF_FAR,\n","                \"origen\":            \"transito_sin_lote\"\n","            }])\n","            cd = pd.concat([cd, nuevos_prep], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","\n","        total_arribos_dia = arribo_lote_qty + arribo_prep_qty\n","        total_consumo_dia = 0.0\n","        total_obs_dia     = 0.0\n","\n","        # ── 1) Reabasto OL → pool de tiendas (una vez por mes) ──\n","        es_primer_dia_horizonte = (dia == process_date)\n","        if mes_id not in meses_reabastecidos and (primer_dia or es_primer_dia_horizonte):\n","            consumo_mes_pool  = float(fc_lookup.get((item, mes_id), 0.0))\n","            stock_actual_pool = float(tienda_pool[\"qty\"].sum()) if not tienda_pool.empty else 0.0\n","            necesidad         = max(0.0, consumo_mes_pool - stock_actual_pool)\n","\n","            while necesidad > 1e-9 and not cd.empty:\n","                disponible_cd = float(cd.at[0, \"qty\"])\n","                transfer_qty  = min(disponible_cd, necesidad)\n","                nuevo_lote    = cd.iloc[0].copy()\n","                nuevo_lote[\"qty\"] = transfer_qty\n","                tienda_pool = pd.concat(\n","                    [tienda_pool, pd.DataFrame([nuevo_lote])],\n","                    ignore_index=True\n","                ).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","                cd.at[0, \"qty\"] = disponible_cd - transfer_qty\n","                if cd.at[0, \"qty\"] <= 1e-9:\n","                    cd = cd.iloc[1:].reset_index(drop=True)\n","                necesidad -= transfer_qty\n","\n","            meses_reabastecidos.add(mes_id)\n","\n","        # ── 2) Vencimientos en el pool de tiendas ──\n","        while not tienda_pool.empty and dia >= tienda_pool.iloc[0][\"fecha_fin_consumo\"]:\n","            lote    = tienda_pool.iloc[0]\n","            obs_qty = float(lote[\"qty\"])\n","            total_obs_dia += obs_qty\n","            obs_rows.append({\n","                \"item_no\":                     item,\n","                \"store_code\":                  TIENDA_POOL_LABEL,\n","                \"expiration_date\":             lote[\"expiration_date\"],\n","                \"fecha_fin_consumo\":           lote[\"fecha_fin_consumo\"],\n","                \"obs_date\":                    dia,\n","                \"qty_vencida\":                 obs_qty,\n","                \"origen\":                      lote[\"origen\"],\n","                \"Home_Furnishing_Business_No\": hfb,\n","                \"process_date\":                process_date\n","            })\n","            tienda_pool = tienda_pool.iloc[1:].reset_index(drop=True)\n","\n","        # ── 3) Vencimientos en OL ──\n","        while not cd.empty and dia >= cd.iloc[0][\"fecha_fin_consumo\"]:\n","            lote    = cd.iloc[0]\n","            obs_qty = float(lote[\"qty\"])\n","            total_obs_dia += obs_qty\n","            obs_rows.append({\n","                \"item_no\":                     item,\n","                \"store_code\":                  \"CD\",\n","                \"expiration_date\":             lote[\"expiration_date\"],\n","                \"fecha_fin_consumo\":           lote[\"fecha_fin_consumo\"],\n","                \"obs_date\":                    dia,\n","                \"qty_vencida\":                 obs_qty,\n","                \"origen\":                      lote[\"origen\"],\n","                \"Home_Furnishing_Business_No\": hfb,\n","                \"process_date\":                process_date\n","            })\n","            cd = cd.iloc[1:].reset_index(drop=True)\n","\n","        # ── 4) Consumo diario desde el pool de tiendas ──\n","        consumo_rest = float(fc_diario_lookup.get((item, mes_id), 0.0))\n","        while consumo_rest > 1e-9:\n","            if tienda_pool.empty or float(tienda_pool[\"qty\"].sum()) <= 0:\n","                break\n","            disponible = float(tienda_pool.at[0, \"qty\"])\n","            vendido    = min(disponible, consumo_rest)\n","            tienda_pool.at[0, \"qty\"] = disponible - vendido\n","            consumo_rest -= vendido\n","            total_consumo_dia += vendido\n","            if tienda_pool.at[0, \"qty\"] <= 1e-9:\n","                tienda_pool = tienda_pool.iloc[1:].reset_index(drop=True)\n","\n","        inv_fin_dia = float(cd[\"qty\"].sum()) + float(tienda_pool[\"qty\"].sum())\n","\n","        daily_rows.append({\n","            \"item_no\":                     item,\n","            \"date\":                        dia,\n","            \"inventory_pre\":               inv_inicio_dia,\n","            \"inventory\":                   inv_fin_dia,\n","            \"consumption\":                 total_consumo_dia,\n","            \"arrivals\":                    total_arribos_dia,\n","            \"expiration\":                  total_obs_dia,\n","            \"Home_Furnishing_Business_No\": hfb,\n","            \"process_date\":                process_date\n","        })\n","\n","obs_df   = pd.DataFrame(obs_rows) if obs_rows else pd.DataFrame(columns=_obs_schema)\n","daily_df = pd.DataFrame(daily_rows)\n","\n","print(\"✅ Motor diario terminado (pool de tiendas consolidado)\")\n","print(\"Obsolescencia lotes:\", obs_df.shape)\n","print(\"Balance diario:     \", daily_df.shape)\n","\n","if not obs_df.empty:\n","    print(\"\\nVencimiento por origen:\")\n","    print(obs_df.groupby([\"origen\", \"store_code\"])[\"qty_vencida\"].sum()\n","          .reset_index().sort_values(\"qty_vencida\", ascending=False).to_string(index=False))\n"]},{"cell_type":"code","source":["### CELDA 10-B — Trazabilidad de vencimiento por item (diagnóstico) ###\n","# Muestra mes a mes cómo se consume/vence el stock de UN item específico,\n","# para auditar por qué el vencimiento proyectado cambia entre corridas.\n","# Requiere haber corrido CELDA 10 antes (usa daily_df, obs_df, forecast_pool).\n","\n","ITEM_DEBUG = \"789000039\"  # <-- cambiar por el item a revisar (ej. albóndiga)\n","\n","# 1) Resumen mensual: stock, demanda vs consumo real, arribos, vencimiento\n","trace_daily = daily_df[daily_df[\"item_no\"] == ITEM_DEBUG].copy()\n","trace_daily[\"mes_id\"] = trace_daily[\"date\"].dt.to_period(\"M\").astype(str)\n","\n","resumen_mensual = (\n","    trace_daily.sort_values(\"date\")\n","    .groupby(\"mes_id\", as_index=False)\n","    .agg(\n","        inventory_initial=(\"inventory_pre\", \"first\"),\n","        inventory_final=(\"inventory\", \"last\"),\n","        consumption=(\"consumption\", \"sum\"),\n","        arrivals=(\"arrivals\", \"sum\"),\n","        expiration=(\"expiration\", \"sum\"),\n","    )\n",")\n","\n","demanda_mensual = forecast_pool[forecast_pool[\"item_no\"] == ITEM_DEBUG][\n","    [\"mes_id\", \"consumo_mes\"]\n","].rename(columns={\"consumo_mes\": \"demanda_forecast\"})\n","\n","resumen_mensual = resumen_mensual.merge(demanda_mensual, on=\"mes_id\", how=\"left\")\n","resumen_mensual[\"demanda_forecast\"] = resumen_mensual[\"demanda_forecast\"].fillna(0.0)\n","resumen_mensual[\"demanda_no_cubierta\"] = (\n","    resumen_mensual[\"demanda_forecast\"] - resumen_mensual[\"consumption\"]\n",").clip(lower=0)\n","\n","cols = [\"mes_id\", \"inventory_initial\", \"demanda_forecast\", \"consumption\",\n","        \"demanda_no_cubierta\", \"arrivals\", \"expiration\", \"inventory_final\"]\n","\n","print(f\"=== Resumen mensual — item {ITEM_DEBUG} ===\")\n","print(resumen_mensual[cols].round(1).to_string(index=False))\n","\n","# 2) Detalle de lotes involucrados en vencimiento (para ver origen y fecha exacta)\n","print(f\"\\n=== Lotes con vencimiento proyectado — item {ITEM_DEBUG} ===\")\n","detalle_obs = obs_df[obs_df[\"item_no\"] == ITEM_DEBUG].copy()\n","if detalle_obs.empty:\n","    print(\"(sin vencimiento proyectado para este item)\")\n","else:\n","    detalle_obs = detalle_obs.sort_values(\"obs_date\")\n","    print(detalle_obs[[\n","        \"store_code\", \"origen\", \"expiration_date\", \"fecha_fin_consumo\",\n","        \"obs_date\", \"qty_vencida\"\n","    ]].to_string(index=False))\n","    print(f\"\\nTotal vencimiento proyectado: {detalle_obs['qty_vencida'].sum():.1f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jUdY-SwmMuvv","executionInfo":{"status":"ok","timestamp":1784127384674,"user_tz":240,"elapsed":19,"user":{"displayName":"Francisco Enrique González Morales","userId":"17046962551082790183"}},"outputId":"f347614d-621a-4e7d-d74f-68ba0542984b"},"execution_count":31,"outputs":[{"output_type":"stream","name":"stdout","text":["=== Resumen mensual — item 789000039 ===\n"," mes_id  inventory_initial  demanda_forecast  consumption  demanda_no_cubierta  arrivals  expiration  inventory_final\n","2026-07            17063.0            1168.5       1168.5                  0.0       0.0         0.0          15894.5\n","2026-08            15894.5            1675.6       1675.6                  0.0       0.0         0.0          14219.0\n","2026-09            14219.0            1411.0       1411.0                  0.0       0.0         0.0          12808.0\n","2026-10            12808.0            1657.7       1657.7                  0.0       0.0         0.0          11150.3\n","2026-11            11150.3            1686.6       1686.6                  0.0       0.0         0.0           9463.7\n","2026-12             9463.7            1606.0        924.3                681.7       0.0       681.7           7857.7\n","2027-01             7857.7            1579.3       1579.3                  0.0       0.0         0.0           6278.4\n","2027-02             6278.4            1619.5       1619.5                  0.0       0.0         0.0           4659.0\n","2027-03             4659.0            1765.0        626.3               1138.7       0.0      4032.7              0.0\n","2027-04                0.0            1759.0          0.0               1759.0       0.0         0.0              0.0\n","2027-05                0.0            1846.8          0.0               1846.8       0.0         0.0              0.0\n","2027-06                0.0            1971.7          0.0               1971.7       0.0         0.0              0.0\n","2027-07                0.0            1980.8          0.0               1980.8       0.0         0.0              0.0\n","\n","=== Lotes con vencimiento proyectado — item 789000039 ===\n","store_code     origen expiration_date fecha_fin_consumo   obs_date  qty_vencida\n","   TIENDAS OL_inicial      2026-12-03        2026-12-03 2026-12-03   681.696242\n","   TIENDAS OL_inicial      2027-03-12        2027-03-12 2027-03-12  1138.692997\n","        CD OL_inicial      2027-03-12        2027-03-12 2027-03-12  2893.995870\n","\n","Total vencimiento proyectado: 4714.4\n"]}]},{"cell_type":"code","source":["### CELDA 10-C — Trazabilidad MENSUAL por LOTE (item específico) ###\n","# Re-simula el motor SOLO para un item, registrando cada evento por lote\n","# (entrada, consumo, vencimiento, reabasto) y arma un resumen mes a mes\n","# con el remanente acumulado de cada lote.\n","\n","ITEM_DEBUG = \"789000039\"  # <-- cambiar por el item a revisar (ej. albóndiga)\n","\n","hfb_series = items_master.loc[items_master[\"item_no\"] == ITEM_DEBUG, \"Home_Furnishing_Business_No\"]\n","hfb        = int(hfb_series.iloc[0]) if len(hfb_series) > 0 and pd.notna(hfb_series.iloc[0]) else None\n","dias_corte = dias_corte_por_hfb(hfb)\n","\n","# --- Stock OL inicial, con lote_id ---\n","cd_dbg = stock_cd_por_vencimiento[stock_cd_por_vencimiento[\"item_no\"] == ITEM_DEBUG][\n","    [\"expiration_date\", \"qty\"]\n","].copy()\n","cd_dbg[\"expiration_date\"] = pd.to_datetime(cd_dbg[\"expiration_date\"]).dt.normalize()\n","cd_dbg[\"qty\"]    = cd_dbg[\"qty\"].astype(float)\n","cd_dbg[\"origen\"] = \"OL_inicial\"\n","if not cd_dbg.empty:\n","    cd_dbg[\"fecha_fin_consumo\"] = cd_dbg[\"expiration_date\"] - pd.Timedelta(days=dias_corte)\n","    cd_dbg = cd_dbg[cd_dbg[\"fecha_fin_consumo\"] >= process_date].reset_index(drop=True)\n","else:\n","    cd_dbg = pd.DataFrame(columns=[\"expiration_date\", \"qty\", \"fecha_fin_consumo\", \"origen\"])\n","cd_dbg = cd_dbg.sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","cd_dbg[\"lote_id\"] = [f\"OL_{i+1}_{row.expiration_date.date()}\" for i, row in cd_dbg.iterrows()]\n","\n","# --- Stock tienda inicial (pool), con lote_id ---\n","tp_dbg = stock_tienda_por_vencimiento[\n","    stock_tienda_por_vencimiento[\"item_no\"] == ITEM_DEBUG\n","][[\"expiration_date\", \"qty\"]].copy()\n","tp_dbg[\"expiration_date\"]   = pd.to_datetime(tp_dbg[\"expiration_date\"]).dt.normalize()\n","tp_dbg[\"qty\"]               = tp_dbg[\"qty\"].astype(float)\n","tp_dbg[\"origen\"]            = \"tienda_inicial\"\n","tp_dbg[\"fecha_fin_consumo\"] = tp_dbg[\"expiration_date\"] - pd.Timedelta(days=dias_corte)\n","tp_dbg = tp_dbg[tp_dbg[\"fecha_fin_consumo\"] >= process_date].reset_index(drop=True)\n","tp_dbg = tp_dbg.sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","tp_dbg[\"lote_id\"] = [f\"TIENDA_{i+1}_{row.expiration_date.date()}\" for i, row in tp_dbg.iterrows()]\n","\n","_next_lote_seq = {\"OL\": len(cd_dbg), \"TIENDA\": len(tp_dbg)}\n","ledger = []\n","\n","# --- Registrar ENTRADA inicial de cada lote (día 0) ---\n","for _, lote in cd_dbg.iterrows():\n","    ledger.append({\n","        \"date\": process_date, \"lote_id\": lote[\"lote_id\"], \"origen\": lote[\"origen\"],\n","        \"ubicacion\": \"CD\", \"evento\": \"entrada\",\n","        \"qty_evento\": float(lote[\"qty\"]), \"expiration_date\": lote[\"expiration_date\"],\n","        \"fecha_fin_consumo\": lote[\"fecha_fin_consumo\"]\n","    })\n","for _, lote in tp_dbg.iterrows():\n","    ledger.append({\n","        \"date\": process_date, \"lote_id\": lote[\"lote_id\"], \"origen\": lote[\"origen\"],\n","        \"ubicacion\": \"TIENDAS\", \"evento\": \"entrada\",\n","        \"qty_evento\": float(lote[\"qty\"]), \"expiration_date\": lote[\"expiration_date\"],\n","        \"fecha_fin_consumo\": lote[\"fecha_fin_consumo\"]\n","    })\n","\n","meses_reabastecidos_dbg = set()\n","\n","for dia in calendario:\n","    mes_id     = dia.to_period(\"M\").strftime(\"%Y-%m\")\n","    primer_dia = (dia == dia.to_period(\"M\").to_timestamp())\n","\n","    # 0a) Arribos con lote -> CD\n","    lotes_hoy = arribos_lote[\n","        (arribos_lote[\"item_no\"] == ITEM_DEBUG) &\n","        (arribos_lote[\"available_date\"] == dia)\n","    ]\n","    if not lotes_hoy.empty:\n","        nuevos = lotes_hoy[[\"expiration_date\", \"qty\"]].copy()\n","        nuevos[\"expiration_date\"] = pd.to_datetime(nuevos[\"expiration_date\"]).dt.normalize()\n","        nuevos[\"qty\"]    = nuevos[\"qty\"].astype(float)\n","        nuevos[\"origen\"] = \"transito_lote\"\n","        nuevos[\"fecha_fin_consumo\"] = nuevos[\"expiration_date\"] - pd.Timedelta(days=dias_corte)\n","        nuevos = nuevos[nuevos[\"fecha_fin_consumo\"] >= dia]\n","        for _, r in nuevos.iterrows():\n","            _next_lote_seq[\"OL\"] += 1\n","            r = r.copy()\n","            r[\"lote_id\"] = f\"OL_{_next_lote_seq['OL']}_{r['expiration_date'].date()}\"\n","            cd_dbg = pd.concat([cd_dbg, pd.DataFrame([r])], ignore_index=True)\n","            ledger.append({\n","                \"date\": dia, \"lote_id\": r[\"lote_id\"], \"origen\": r[\"origen\"],\n","                \"ubicacion\": \"CD\", \"evento\": \"entrada\",\n","                \"qty_evento\": float(r[\"qty\"]), \"expiration_date\": r[\"expiration_date\"],\n","                \"fecha_fin_consumo\": r[\"fecha_fin_consumo\"]\n","            })\n","        cd_dbg = cd_dbg.sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","\n","    # 0b) Arribos sin lote -> CD\n","    prep_hoy = arribos_sin_lote[\n","        (arribos_sin_lote[\"item_no\"] == ITEM_DEBUG) &\n","        (arribos_sin_lote[\"available_date\"] == dia)\n","    ]\n","    arribo_prep_qty = float(prep_hoy[\"qty\"].sum()) if not prep_hoy.empty else 0.0\n","    if arribo_prep_qty > 0:\n","        _next_lote_seq[\"OL\"] += 1\n","        lote_id_prep = f\"OL_{_next_lote_seq['OL']}_sin_lote\"\n","        nuevos_prep = pd.DataFrame([{\n","            \"expiration_date\": SHELF_FAR, \"qty\": arribo_prep_qty,\n","            \"fecha_fin_consumo\": SHELF_FAR, \"origen\": \"transito_sin_lote\",\n","            \"lote_id\": lote_id_prep\n","        }])\n","        cd_dbg = pd.concat([cd_dbg, nuevos_prep], ignore_index=True).sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","        ledger.append({\n","            \"date\": dia, \"lote_id\": lote_id_prep, \"origen\": \"transito_sin_lote\",\n","            \"ubicacion\": \"CD\", \"evento\": \"entrada\",\n","            \"qty_evento\": arribo_prep_qty, \"expiration_date\": SHELF_FAR,\n","            \"fecha_fin_consumo\": SHELF_FAR\n","        })\n","\n","    # 1) Reabasto OL -> pool tienda (1 vez por mes) — conserva lote_id de origen\n","    es_primer_dia_horizonte = (dia == process_date)\n","    if mes_id not in meses_reabastecidos_dbg and (primer_dia or es_primer_dia_horizonte):\n","        consumo_mes_pool  = float(fc_lookup.get((ITEM_DEBUG, mes_id), 0.0))\n","        stock_actual_pool = float(tp_dbg[\"qty\"].sum()) if not tp_dbg.empty else 0.0\n","        necesidad = max(0.0, consumo_mes_pool - stock_actual_pool)\n","\n","        while necesidad > 1e-9 and not cd_dbg.empty:\n","            disponible_cd = float(cd_dbg.at[0, \"qty\"])\n","            transfer_qty  = min(disponible_cd, necesidad)\n","            nuevo_lote = cd_dbg.iloc[0].copy()\n","            nuevo_lote[\"qty\"] = transfer_qty\n","            tp_dbg = pd.concat([tp_dbg, pd.DataFrame([nuevo_lote])], ignore_index=True) \\\n","                       .sort_values(\"fecha_fin_consumo\").reset_index(drop=True)\n","            ledger.append({\n","                \"date\": dia, \"lote_id\": nuevo_lote[\"lote_id\"], \"origen\": nuevo_lote[\"origen\"],\n","                \"ubicacion\": \"TIENDAS\", \"evento\": \"reabasto_desde_OL\",\n","                \"qty_evento\": transfer_qty, \"expiration_date\": nuevo_lote[\"expiration_date\"],\n","                \"fecha_fin_consumo\": nuevo_lote[\"fecha_fin_consumo\"]\n","            })\n","            cd_dbg.at[0, \"qty\"] = disponible_cd - transfer_qty\n","            if cd_dbg.at[0, \"qty\"] <= 1e-9:\n","                cd_dbg = cd_dbg.iloc[1:].reset_index(drop=True)\n","            necesidad -= transfer_qty\n","\n","        meses_reabastecidos_dbg.add(mes_id)\n","\n","    # 2) Vencimientos en tienda\n","    while not tp_dbg.empty and dia >= tp_dbg.iloc[0][\"fecha_fin_consumo\"]:\n","        lote = tp_dbg.iloc[0]\n","        ledger.append({\n","            \"date\": dia, \"lote_id\": lote[\"lote_id\"], \"origen\": lote[\"origen\"],\n","            \"ubicacion\": \"TIENDAS\", \"evento\": \"VENCIMIENTO\",\n","            \"qty_evento\": float(lote[\"qty\"]), \"expiration_date\": lote[\"expiration_date\"],\n","            \"fecha_fin_consumo\": lote[\"fecha_fin_consumo\"]\n","        })\n","        tp_dbg = tp_dbg.iloc[1:].reset_index(drop=True)\n","\n","    # 3) Vencimientos en CD\n","    while not cd_dbg.empty and dia >= cd_dbg.iloc[0][\"fecha_fin_consumo\"]:\n","        lote = cd_dbg.iloc[0]\n","        ledger.append({\n","            \"date\": dia, \"lote_id\": lote[\"lote_id\"], \"origen\": lote[\"origen\"],\n","            \"ubicacion\": \"CD\", \"evento\": \"VENCIMIENTO\",\n","            \"qty_evento\": float(lote[\"qty\"]), \"expiration_date\": lote[\"expiration_date\"],\n","            \"fecha_fin_consumo\": lote[\"fecha_fin_consumo\"]\n","        })\n","        cd_dbg = cd_dbg.iloc[1:].reset_index(drop=True)\n","\n","    # 4) Consumo diario desde pool tienda\n","    consumo_rest = float(fc_diario_lookup.get((ITEM_DEBUG, mes_id), 0.0))\n","    while consumo_rest > 1e-9:\n","        if tp_dbg.empty or float(tp_dbg[\"qty\"].sum()) <= 0:\n","            break\n","        lote_id_actual = tp_dbg.at[0, \"lote_id\"]\n","        disponible = float(tp_dbg.at[0, \"qty\"])\n","        vendido    = min(disponible, consumo_rest)\n","        tp_dbg.at[0, \"qty\"] = disponible - vendido\n","        consumo_rest -= vendido\n","        ledger.append({\n","            \"date\": dia, \"lote_id\": lote_id_actual, \"origen\": tp_dbg.at[0, \"origen\"],\n","            \"ubicacion\": \"TIENDAS\", \"evento\": \"consumo\",\n","            \"qty_evento\": vendido, \"expiration_date\": tp_dbg.at[0, \"expiration_date\"],\n","            \"fecha_fin_consumo\": tp_dbg.at[0, \"fecha_fin_consumo\"]\n","        })\n","        if tp_dbg.at[0, \"qty\"] <= 1e-9:\n","            tp_dbg = tp_dbg.iloc[1:].reset_index(drop=True)\n","\n","ledger_df = pd.DataFrame(ledger)\n","\n","# ── Resumen mensual por lote, con remanente acumulado ──\n","print(f\"=== Remanente mensual por lote — item {ITEM_DEBUG} ===\\n\")\n","\n","if ledger_df.empty:\n","    print(\"(sin eventos)\")\n","else:\n","    ledger_df[\"mes_id\"] = pd.to_datetime(ledger_df[\"date\"]).dt.to_period(\"M\").astype(str)\n","\n","    pivot_mensual = (\n","        ledger_df.pivot_table(\n","            index=[\"lote_id\", \"origen\", \"expiration_date\", \"fecha_fin_consumo\", \"mes_id\"],\n","            columns=\"evento\", values=\"qty_evento\", aggfunc=\"sum\", fill_value=0.0\n","        ).reset_index()\n","    )\n","    for col in [\"entrada\", \"reabasto_desde_OL\", \"consumo\", \"VENCIMIENTO\"]:\n","        if col not in pivot_mensual.columns:\n","            pivot_mensual[col] = 0.0\n","\n","    pivot_mensual[\"entradas_mes\"]    = pivot_mensual[\"entrada\"] + pivot_mensual[\"reabasto_desde_OL\"]\n","    pivot_mensual[\"consumo_mes\"]     = pivot_mensual[\"consumo\"]\n","    pivot_mensual[\"vencimiento_mes\"] = pivot_mensual[\"VENCIMIENTO\"]\n","    pivot_mensual[\"neto_mes\"] = (\n","        pivot_mensual[\"entradas_mes\"] - pivot_mensual[\"consumo_mes\"] - pivot_mensual[\"vencimiento_mes\"]\n","    )\n","\n","    pivot_mensual = pivot_mensual.sort_values([\"lote_id\", \"mes_id\"])\n","    pivot_mensual[\"remanente\"] = pivot_mensual.groupby(\"lote_id\")[\"neto_mes\"].cumsum()\n","\n","    cols_show = [\"lote_id\", \"origen\", \"mes_id\", \"entradas_mes\", \"consumo_mes\",\n","                 \"vencimiento_mes\", \"remanente\", \"expiration_date\", \"fecha_fin_consumo\"]\n","\n","    for lid, grp in pivot_mensual.groupby(\"lote_id\"):\n","        primero = grp.iloc[0]\n","        print(f\"--- {lid}  (origen={primero['origen']}, vence={primero['expiration_date'].date()}, corte={primero['fecha_fin_consumo'].date()}) ---\")\n","        print(grp[cols_show].drop(columns=[\"lote_id\",\"origen\",\"expiration_date\",\"fecha_fin_consumo\"]).round(1).to_string(index=False))\n","        print()\n","\n","pivot_mensual.head(30) if not ledger_df.empty else None"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"b0GInDYENy6R","executionInfo":{"status":"ok","timestamp":1784127385599,"user_tz":240,"elapsed":895,"user":{"displayName":"Francisco Enrique González Morales","userId":"17046962551082790183"}},"outputId":"10a282e9-bf0e-427d-fdf1-3a175ce48478"},"execution_count":32,"outputs":[{"output_type":"stream","name":"stdout","text":["=== Remanente mensual por lote — item 789000039 ===\n","\n","--- OL_1_2026-12-03  (origen=OL_inicial, vence=2026-12-03, corte=2026-12-03) ---\n"," mes_id  entradas_mes  consumo_mes  vencimiento_mes  remanente\n","2026-07        5424.0          0.0              0.0     5424.0\n","2026-09        1294.4       1294.4              0.0     5424.0\n","2026-10        1657.7       1657.7              0.0     5424.0\n","2026-11        1686.6       1686.6              0.0     5424.0\n","2026-12         785.3        103.6            681.7     5424.0\n","\n","--- OL_2_2027-03-12  (origen=OL_inicial, vence=2027-03-12, corte=2027