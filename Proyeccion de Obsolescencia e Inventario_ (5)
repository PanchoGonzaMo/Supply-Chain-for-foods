s\": [\n    {\n      \"column\": \"item_no\",\n      \"properties\": {\n        \"dtype\": \"category\",\n        \"num_unique_values\": 258,\n        \"samples\": [\n          \"789000106\",\n          \"789000078\",\n          \"789000015\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"store_code\",\n      \"properties\": {\n        \"dtype\": \"category\",\n        \"num_unique_values\": 2,\n        \"samples\": [\n          \"63600\",\n          \"59400\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"mes_id\",\n      \"properties\": {\n        \"dtype\": \"object\",\n        \"num_unique_values\": 37,\n        \"samples\": [\n          \"2025-12\",\n          \"2025-08\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"consumo_mes\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 3224.3974534366785,\n        \"min\": 0.0111964,\n        \"max\": 57776.79898690761,\n        \"num_unique_values\": 12425,\n        \"samples\": [\n          776.8404278313124,\n          43.18266460153106\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{},"execution_count":28}],"source":["### CELDA 8 — Forecast desde BOM ###\n","\n","col_no = \"`No`\"\n","\n","forecast_bom = read_gbq(\n","    f\"\"\"\n","    WITH receta AS (\n","\n","        -- Rama 1: insumos 789 dentro de recetas 598 (HFB=60)\n","        SELECT\n","            TRIM(CAST(Position AS STRING))                        AS codigo_receta,\n","            TRIM(CAST({col_no} AS STRING))                        AS codigo_insumo,\n","            COALESCE(SAFE_CAST(Quantity_per AS FLOAT64), 0)       AS quantity_per,\n","            UPPER(TRIM(CAST(BOM_Unit_of_Measure_Code AS STRING))) AS bom_uom,\n","            UPPER(TRIM(CAST(Base_UoM AS STRING)))                 AS base_uom\n","        FROM `{PROJECT_ID}.{DATASET}.BOM_df`\n","        WHERE STARTS_WITH(TRIM(CAST(Position AS STRING)), '598')\n","          AND STARTS_WITH(TRIM(CAST({col_no} AS STRING)), '789')\n","\n","        UNION ALL\n","\n","        -- Rama 2: productos HFB=61 con forecast directo (Position = No = 789...)\n","        SELECT\n","            TRIM(CAST(Position AS STRING))                        AS codigo_receta,\n","            TRIM(CAST({col_no} AS STRING))                        AS codigo_insumo,\n","            COALESCE(SAFE_CAST(Quantity_per AS FLOAT64), 0)       AS quantity_per,\n","            UPPER(TRIM(CAST(BOM_Unit_of_Measure_Code AS STRING))) AS bom_uom,\n","            UPPER(TRIM(CAST(Base_UoM AS STRING)))                 AS base_uom\n","        FROM `{PROJECT_ID}.{DATASET}.BOM_df`\n","        WHERE STARTS_WITH(TRIM(CAST(Position AS STRING)), '789')\n","          AND TRIM(CAST(Position AS STRING)) = TRIM(CAST({col_no} AS STRING))\n","          AND TRIM(CAST({col_no} AS STRING)) IN (\n","              SELECT TRIM(CAST({col_no} AS STRING))\n","              FROM `{PROJECT_ID}.{DATASET}.items`\n","              WHERE TRIM(CAST(Home_Furnishing_Business_No AS STRING)) IN ('60', '61')\n","          )\n","    ),\n","\n","    fcst_src AS (\n","        SELECT\n","            TRIM(CAST(Item_No AS STRING)) AS codigo_receta,\n","            Tienda,\n","            SAFE_CAST(Ano_Fcst AS INT64)  AS Ano_Fcst,\n","            SAFE_CAST(Mes_Fcst AS INT64)  AS Mes_Fcst,\n","            SAFE_CAST(Fcst AS FLOAT64)    AS Fcst,\n","            SAFE.PARSE_DATE(\n","                '%d%m%Y',\n","                CONCAT('01', LPAD(REGEXP_REPLACE(CAST(Llave_calculo AS STRING), r'[^0-9]', ''), 6, '0'))\n","            ) AS fecha_calculo\n","        FROM `{PROJECT_ID}.{DATASET}.Hist Fcst mensual`\n","        WHERE Fcst IS NOT NULL\n","          AND (\n","              STARTS_WITH(TRIM(CAST(Item_No AS STRING)), '598')  -- recetas HFB=60\n","              OR STARTS_WITH(TRIM(CAST(Item_No AS STRING)), '789') -- productos directos HFB=61\n","          )\n","    ),\n","\n","    fcst_receta AS (\n","        SELECT codigo_receta, Tienda, Ano_Fcst, Mes_Fcst, Fcst AS fcst\n","        FROM fcst_src\n","        QUALIFY ROW_NUMBER() OVER (\n","            PARTITION BY codigo_receta, Tienda, Ano_Fcst, Mes_Fcst\n","            ORDER BY fecha_calculo DESC NULLS LAST\n","        ) = 1\n","    ),\n","\n","    necesidad_insumo AS (\n","        SELECT\n","            f.Tienda,\n","            r.codigo_insumo AS item_no,\n","            f.Ano_Fcst,\n","            f.Mes_Fcst,\n","            CASE\n","                WHEN r.bom_uom IN ('GR','G') AND r.base_uom = 'KG'\n","                    THEN f.fcst * r.quantity_per / 1000\n","                WHEN r.bom_uom = 'KG' AND r.base_uom = 'KG'\n","                    THEN f.fcst * r.quantity_per\n","                WHEN r.bom_uom IN ('PC','EA','UN','UNIT') AND r.base_uom IN ('PC','EA','UN','UNIT')\n","                    THEN f.fcst * r.quantity_per\n","                ELSE 0\n","            END AS necesidad\n","        FROM receta r\n","        JOIN fcst_receta f ON r.codigo_receta = f.codigo_receta\n","    )\n","\n","    SELECT\n","        item_no,\n","        Tienda AS store_code,\n","        CONCAT(CAST(Ano_Fcst AS STRING), '-', LPAD(CAST(Mes_Fcst AS STRING), 2, '0')) AS mes_id,\n","        SUM(necesidad) AS consumo_mes\n","    FROM necesidad_insumo\n","    GROUP BY item_no, store_code, Ano_Fcst, Mes_Fcst\n","    HAVING SUM(necesidad) > 0\n","    ORDER BY item_no, store_code, mes_id\n","    \"\"\",\n","    project_id=PROJECT_ID\n",")\n","\n","# Verificación rápida\n","items_hfb61 = items_master[items_master[\"Home_Furnishing_Business_No\"] == 61][\"item_no\"]\n","n_hfb61 = forecast_bom[forecast_bom[\"item_no\"].isin(items_hfb61)][\"item_no\"].nunique()\n","print(f\"✅ forecast_bom cargado: {len(forecast_bom)} filas\")\n","print(f\"   Items HFB=60 con forecas