  dataTable['output_type'] = 'display_data';\n","        await google.colab.output.renderOutput(dataTable, element);\n","        const docLink = document.createElement('div');\n","        docLink.innerHTML = docLinkHtml;\n","        element.appendChild(docLink);\n","      }\n","    </script>\n","  </div>\n","\n","\n","    </div>\n","  </div>\n"],"application/vnd.google.colaboratory.intrinsic+json":{"type":"dataframe","variable_name":"forecast_mensual","repr_error":"0"}},"metadata":{},"execution_count":29}],"source":["### CELDA 9 — Forecast mensual desde hoy (prorrateo mes actual) ###\n","\n","hoy = pd.Timestamp.today().normalize()\n","ano_actual = hoy.year\n","mes_actual = hoy.month\n","dias_mes = hoy.days_in_month\n","dia_actual = hoy.day\n","dias_restantes = dias_mes - dia_actual + 1  # días que quedan (incluye hoy)\n","\n","forecast_mensual = forecast_bom.copy()\n","forecast_mensual[\"ano\"] = forecast_mensual[\"mes_id\"].str[:4].astype(int)\n","forecast_mensual[\"mes\"] = forecast_mensual[\"mes_id\"].str[5:7].astype(int)\n","forecast_mensual[\"es_mes_actual\"] = (\n","    (forecast_mensual[\"ano\"] == ano_actual) &\n","    (forecast_mensual[\"mes\"] == mes_actual)\n",")\n","\n","# Ajuste proporcional del mes en curso\n","forecast_mensual[\"consumo_mes\"] = np.where(\n","    forecast_mensual[\"es_mes_actual\"],\n","    forecast_mensual[\"consumo_mes\"] * (dias_restantes / dias_mes),\n","    forecast_mensual[\"consumo_mes\"]\n",")\n","\n","mes_actual_id = f\"{ano_actual}-{mes_actual:02d}\"\n","forecast_mensual = forecast_mensual[forecast_mensual[\"mes_id\"] >= mes_actual_id].copy()\n","forecast_mensual = forecast_mensual[[\"item_no\", \"store_code\", \"mes_id\", \"consumo_mes\"]]\n","\n","# ── FIX: normalización de store_code ──\n","# Hist Fcst mensual trae códigos numéricos de tienda (59400, 63600),\n","# mientras que stock_tienda_por_vencimiento_fefo (y por lo tanto tiendas_stock\n","# en CELDA 10) usa formato texto (594_IFB, 636_IFB). Sin este mapeo, los\n","# lookups fc_lookup / fc_diario_lookup en CELDA 10 nunca hacen match,\n","# el consumo diario queda en 0, y todo el stock termina venciendo de golpe.\n","STORE_CODE_MAP = {\n","    \"59400\": \"594_IFB\",\n","    \"63600\": \"636_IFB\",\n","}\n","forecast_mensual[\"store_code\"] = (\n","    forecast_mensual[\"store_code\"]\n","    .astype(str)\n","    .str.replace(r\"\\.0$\", \"\", regex=True)   # por si llega como float \"59400.0\"\n","    .map(STORE_CODE_MAP)\n","    .fillna(forecast_mensual[\"store_code\"].astype(str))  # no pierde items si aparece un código nuevo\n",")\n","\n","n_sin_mapear = (~forecast_mensual[\"store_code\"].isin(STORE_CODE_MAP.values())).sum()\n","if n_sin_mapear > 0:\n","    print(f\"⚠️  {n_sin_mapear} filas con store_code fuera del mapeo esperado (revisar):\")\n","    print(forecast_mensual.loc[~forecast_mensual[\"store_code\"].isin(STORE_CODE_MAP.values()), \"store_code\"].unique())\n","\n","forecast_mensual.sort_values([\"item_no\", \"store_code\", \"mes_id\"], inplace=True)\n","\n","# ── FIX 5: consumo diario usa días_restantes para mes actual, días completos para los demás ──\n","forecast_mensual[\"dias_mes\"] = forecast_mensual[\"mes_id\"].apply(lambda x: pd.Period(x, freq=\"M\").days_in_month)\n","forecast_mensual[\"dias_denominador\"] = np.where(\n","    forecast_mensual[\"mes_id\"] == mes_actual_id,\n","    dias_restantes,\n","    forecast_mensual[\"dias_mes\"]\n",")\n","forecast_mensual[\"consumo_diario\"] = (\n","    forecast_mensual[\"consumo_mes\"] / forecast_mensual[\"dias_denominador\"]\n",")\n","\n","forecast_mensual.head()\n"]},{"cell_type":"code","execution_count":30,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":135632,"status":"ok","timestamp":1784127384657,"user":{"displayName":"Francisco Enrique González Morales","userId":"17046962551082790183"},"user_tz":240},"id":"n6iTc6rPAca1","outputId":"7fc1fda8-805a-469d-a8a0-2b97522cfad4"},"outputs":[{"output_type":"stream","name":"stderr","te