OAT64)) AS qty\n","    FROM `{PROJECT_ID}.{DATASET}.Seguimiento_Importaciones`\n","    WHERE Estado_Importacion = 'En transito'\n","      AND Fecha_Liberacion_Estimada IS NOT NULL\n","      AND BBD IS NOT NULL\n","      AND SAFE_CAST(Cantidad_UoM_Base AS FLOAT64) > 0\n","      AND Codigo_MVBC IN (\n","          SELECT TRIM(CAST(`No` AS STRING))\n","          FROM `{PROJECT_ID}.{DATASET}.items`\n","          WHERE SAFE_CAST(Home_Furnishing_Business_No AS INT64) IN (60, 61)\n","      )\n","    GROUP BY item_no, available_date, expiration_date\n","    \"\"\",\n","    project_id=PROJECT_ID\n",")\n","\n","arribos_lote[\"available_date\"]  = pd.to_datetime(arribos_lote[\"available_date\"]).dt.normalize()\n","arribos_lote[\"expiration_date\"] = pd.to_datetime(arribos_lote[\"expiration_date\"]).dt.normalize()\n","arribos_lote[\"qty\"]             = arribos_lote[\"qty\"].astype(float)\n","\n","arribos_lote.head()\n"]},{"cell_type":"code","execution_count":27,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":1084,"status":"ok","timestamp":1784127247530,"user":{"displayName":"Francisco Enrique González Morales","userId":"17046962551082790183"},"user_tz":240},"id":"K39h6YKqAS4a","outputId":"e0c84010-4c89-4be6-ddb6-a3d9eb6b133d"},"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading: 100%|\u001b[32m██████████\u001b[0m|\n","Downloading: 100%|\u001b[32m██████████\u001b[0m|\n","✅ Celda 7 lista\n","   Tránsito con BBD real:      0 filas\n","   Preparación con BBD estim.: 35 filas → unidos a arribos_lote\n","   Preparación sin historial:  2 filas → quedan en arribos_sin_lote\n"]}],"source":["### CELDA 7 — Tránsitos con BBD estimado para \"En preparación\" ###\n","\n","col_no = \"`No`\"\n","\n","# Paso 1: historial ponderado por producto\n","historico_bbd = read_gbq(f\"\"\"\n","    WITH hist AS (\n","        SELECT\n","            Codigo_MVBC AS item_no,\n","            SAFE_CAST(Cantidad_UoM_Base AS FLOAT64) AS qty,\n","            DATE_DIFF(\n","                SAFE_CAST(BBD AS DATE),\n","                SAFE_CAST(Production_Date AS DATE),\n","                DAY\n","            ) AS vida_util_total,\n","            DATE_DIFF(\n","                SAFE_CAST(Fecha_Liberacion_Estimada AS DATE),\n","                SAFE_CAST(Production_Date AS DATE),\n","                DAY\n","            ) AS dias_consumidos_lib\n","        FROM `{PROJECT_ID}.{DATASET}.Seguimiento_Importaciones`\n","        WHERE Estado_Importacion IN ('En transito', 'Arribado')\n","          AND BBD IS NOT NULL\n","          AND Production_Date IS NOT NULL\n","          AND Fecha_Liberacion_Estimada IS NOT NULL\n","          AND SAFE_CAST(Cantidad_UoM_Base AS FLOAT64) > 0\n","    ),\n","    validos AS (\n","        SELECT *,\n","            SAFE_DIVIDE(dias_consumidos_lib, vida_util_total) AS pct_consumido\n","        FROM hist\n","        WHERE vida_util_total > 0\n","          AND dias_consumidos_lib >= 0\n","          AND SAFE_DIVIDE(dias_consumidos_lib, vida_util_total) BETWEEN 0 AND 1\n","    )\n","    SELECT\n","        item_no,\n","        SAFE_DIVIDE(SUM(vida_util_total * qty), SUM(qty)) AS vida_util_prom,\n","        SAFE_DIVIDE(SUM(pct_consumido * qty),   SUM(qty)) AS pct_consumido_prom,\n","        COUNT(*) AS n_obs\n","    FROM validos\n","    GROUP BY item_no\n","\"\"\", project_id=PROJECT_ID)\n","\n","# Paso 2: productos en preparación\n","arribos_prep_raw = read_gbq(f\"\"\"\n","    SELECT\n","        Codigo_MVBC AS item_no,\n","        SAFE_CAST(Fecha_Liberacion_Estimada AS DATE) AS available_date,\n","        SUM(SAFE_CAST(Cantidad_UoM_Base AS FLOAT64)) AS qty\n","    FROM `{PROJECT_ID}.{DATASET}.Seguimiento_Importaciones`\n","    WHERE Estado_Importacion = 'En preparacion'\n","      AND Fecha_Liberacion_Estimada IS NOT NULL\n","      AND SAFE_CAST(Cantidad_UoM_Base AS FLOAT64) > 0\n","      AND Codigo_MVBC IN (\n","          SELECT TRIM(CAST({col_no} AS STRING))\n","          FROM `{PROJECT_ID}.{DATASET}.items`\n","          WHERE TRIM(CAST(Home_Furnishing_Business_No AS STRING)) IN ('60', '61')\n","      )\n","    GROUP BY item_no, available_date\n","\"\"\", project_id=PROJECT_ID)\n","\n","arribos_prep_raw[\"available_date\"] = pd.to_datetime(arribos_prep_raw[\"available_date\"]).dt.normalize()\n","arribos_prep_raw[\"qty\"]            = arribos_prep_raw[\"qty\"].astype(float)\n","\n","# Paso 3: calcular BBD estimado\n","arribos_prep_raw = arribos_prep_raw.merge(historico_bbd, on=\"item_no\", how=\"left\")\n","arribos_prep_raw[\"dias_restantes\"] = (\n","    arribos_prep_raw[\"vida_util_prom\"] * (1 - arribos_prep_raw[\"pct_consumido_prom\"])\n",").round(0)\n","arribos_prep_raw[\"expiration_date\"] = (\n","    arribos_prep_raw[\"available_date\"] +\n","    pd.to_timedelta(arribos_prep_raw[\"dias_restantes\"].fillna(0), unit=\"D\")\n",")\n","\n","# Paso 4: con BBD estimado → se unen a arribos_lote (tratados igual que tránsito con lote)\n","#          sin historial → quedan como sin_lote (SHELF_FAR, no vencen en horizonte)\n","mask_con_bbd = (\n","    arribos_prep_raw[\"expiration_date\"].notna() &\n","    (arribos_prep_raw[\"dias_restantes\"] > 0)\n",")\n","\n","nuevos_con_bbd = arribos_prep_raw[mask_con_bbd][\n","    [\"item_no\", \"available_date\", \"expiration_date\", \"qty\"]\n","].copy()\n","nuevos_con_bbd[\"origen_estimado\"] = True\n","\n","arribos_lote = pd.concat([arribos_lote, nuevos_con_bbd], ignore_index=True)\n","arribos_lote[\"available_date\"]   = pd.to_datetime(arribos_lote[\"available_date\"]).dt.normalize()\n","arribos_lote[\"expiration_date\"]  = pd.to_datetime(arribos_lote[\"expiration_date\"]).dt.normalize()\n","arribos_lote[\"qty\"]              = arribos_lote[\"qty\"].astype(float)\n","\n","# Los sin historial siguen como sin_lote\n","arribos_sin_lote = arribos_prep_raw[~mask_con_bbd][[\"item_no\", \"available_date\", \"qty\"]].copy()\n","arribos_sin_lote[\"qty\"] = arribos_sin_lote[\"qty\"].astype(float)\n","\n","n_con = len(nuevos_con_bbd)\n","